APP_NAME="NurCRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://numon-hoca.hujjatlar.uz

APP_LOCALE=uz
APP_FALLBACK_LOCALE=uz
APP_FAKER_LOCALE=uz_UZ

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=nurcrm
DB_USERNAME=nurcrm_user
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=numon-hoca.hujjatlar.uz

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_WEBHOOK_URL=https://numon-hoca.hujjatlar.uz/telegram/webhook

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@hujjatlar.uz"
MAIL_FROM_NAME="${APP_NAME}"

HORIZON_NAME=nurcrm
HORIZON_MEMORY_LIMIT=128

VITE_APP_NAME="${APP_NAME}"
